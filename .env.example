# Core n8n Configuration
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_ENCRYPTION_KEY=uVrQuWm46Hk7snkcE5IZIgSnoDqNGpJHoMpF5+5CKzo=
N8N_HOST=${RAILWAY_PUBLIC_DOMAIN}
N8N_PROTOCOL=https
WEBHOOK_URL=https://${RAILWAY_PUBLIC_DOMAIN}
N8N_EDITOR_BASE_URL=https://${RAILWAY_PUBLIC_DOMAIN}

# Database Configuration (Railway PostgreSQL)
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_HOST=${RAILWAY_PRIVATE_DOMAIN}
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_SCHEMA=public

# Community Nodes & External Packages
NODE_FUNCTION_ALLOW_EXTERNAL=cheerio,axios,moment,*
N8N_COMMUNITY_PACKAGES_ENABLED=true

# TelePilot Configuration
EXECUTIONS_PROCESS=main
DEBUG=tdl,tdl:client,telepilot-cred,telepilot-node,telepilot-trigger,telepilot-cm
N8N_LOG_LEVEL=debug

# User Management (required for proper database schema)
N8N_USER_MANAGEMENT_JWT_SECRET=uVrQuWm46Hk7snkcE5IZIgSnoDqNGpJHoMpF5+5CKzo=

# Performance Settings
NODE_ENV=production
PORT=5678
